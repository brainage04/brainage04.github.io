---
import ShellLayout from '@brainage04/astro-shell/components/SiteLayout.astro';
import { navigation } from '../data/navigation';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<ShellLayout
  title={title}
  siteName="brainage04"
  homeTitle="brainage04's website"
  navItems={navigation}
  sourceHref="https://github.com/brainage04/brainage04.github.io"
  faviconHref="/assets/images/graphic-design/profile-pictures/brainage04.jpg"
  faviconType="image/jpeg"
>
  <slot />
</ShellLayout>
