---
import { navigation } from '../data/navigation';

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <nav aria-label="Primary navigation">
    <div class="nav-links">
      {navigation.map((item) => {
        const isActive = item.match?.(pathname) ?? pathname === item.href;
        return (
          <a href={item.href} aria-current={isActive ? 'page' : undefined} data-active={isActive ? 'true' : undefined}>
            {item.name}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: 5;
    background: color-mix(in srgb, var(--background0) 90%, transparent);
    backdrop-filter: blur(12px);
    border-block-end: 1px solid color-mix(in srgb, var(--foreground2) 45%, transparent);
  }

  nav {
    width: min(100% - 1.5rem, 70rem);
    margin-inline: auto;
    display: flex;
    justify-content: center;
    padding-block: clamp(0.65rem, 1.4vw, 0.85rem);
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem clamp(1.55rem, 4vw, 2.7rem);
    align-items: center;
  }

  .nav-links a {
    color: var(--foreground1);
    text-decoration: none;
    border-block-end: 2px solid transparent;
    padding-block: 0.2rem;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .nav-links a:hover,
  .nav-links a[data-active='true'] {
    color: var(--foreground0);
    border-block-end-color: var(--accent-cyan);
  }

  @media (max-width: 520px) {
    nav {
      align-items: flex-start;
    }

    .nav-links {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
