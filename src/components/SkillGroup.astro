---
export interface Props {
  title: string;
  items: string[];
}

const { title, items } = Astro.props;
---

<section class="skill-group terminal-panel" box-="square" shear-="top">
  <h2>{title}</h2>
  <ul marker-="tree">
    {items.map((item) => <li>{item}</li>)}
  </ul>
</section>

<style>
  .skill-group {
    padding: clamp(1.35rem, 2.5vw, 1.85rem);
    line-height: 1.45;
  }

  h2 {
    margin: 0 0 0.8rem;
  }

  ul {
    display: grid;
    gap: 0.5rem;
    margin: 0;
  }

  li + li {
    margin-block-start: 0;
  }
</style>
