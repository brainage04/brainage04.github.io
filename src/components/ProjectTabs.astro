---
import { projectNavigation } from '../data/navigation';

const pathname = Astro.url.pathname;
---

<nav class="project-tabs" aria-label="Project sections">
  {projectNavigation.map((item) => {
    const isActive = pathname === item.href;
    return (
      <a is-="badge" href={item.href} aria-current={isActive ? 'page' : undefined} variant-="background2" data-active={isActive ? 'true' : undefined}>
        {item.name}
      </a>
    );
  })}
</nav>

<style>
  .project-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-block-end: 1.15rem;
  }

  a {
    background: color-mix(in srgb, var(--background3) 82%, var(--accent-cyan) 8%);
    color: var(--foreground0);
    text-decoration: none;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--foreground0) 20%, transparent);
  }

  a[data-active='true'] {
    background: var(--accent-cyan);
    color: var(--background0);
    box-shadow: none;
  }
</style>
