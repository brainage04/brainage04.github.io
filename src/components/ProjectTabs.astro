---
import { projectNavigation } from '../data/navigation';

const pathname = Astro.url.pathname;
---

<nav class="project-tabs" aria-label="Project sections">
  {projectNavigation.map((item) => {
    const isActive = pathname === item.href;
    return (
      <a class="site-badge project-tab" is-="badge" href={item.href} aria-current={isActive ? 'page' : undefined} variant-="background2" data-active={isActive ? 'true' : undefined}>
        <span class="site-badge__label">{item.name}</span>
      </a>
    );
  })}
</nav>

<style>
  .project-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-block-end: 1.15rem;
    line-height: 1.35;
  }

  a {
    --badge-color: color-mix(in srgb, var(--background3) 72%, var(--accent-cyan) 18%);
    --badge-text: var(--foreground0);
    color: var(--badge-text);
    text-decoration: none;
  }

  a[data-active='true'] {
    --badge-color: color-mix(in srgb, var(--accent-cyan) 82%, var(--foreground0));
    --badge-text: var(--background0);
    font-weight: 700;
  }
</style>
