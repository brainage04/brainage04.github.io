---
import { Image } from 'astro:assets';
import { socials } from '../data/socials';
---

<section class="profile-card terminal-panel" box-="square" shear-="top">
  <Image class="avatar" src="/assets/images/graphic-design/profile-pictures/brainage04.jpg" alt="brainage04" width={400} height={400} loading="eager" />
  <div class="profile-copy">
    <div class="name-row">
      <h2>Thomas (brainage04)</h2>
      <div class="socials" aria-label="Social links">
        <a href="mailto:thomasmcmah21@gmail.com" title="Email" aria-label="Email">
          <svg class="social-icon" aria-hidden="true" viewBox="2 4 20 16" height="22">
            <path fill="currentColor" d="M3 5h18v14H3V5Zm2 2v.35l7 4.38 7-4.38V7H5Zm0 2.7V17h14V9.7l-7 4.38L5 9.7Z" />
          </svg>
        </a>
        {socials.map((social) => (
          <a href={social.href} title={social.name} aria-label={social.name} target="_blank" rel="noreferrer">
            <Image src={social.icon} alt="" width={social.iconWidth} height={social.iconHeight} loading="eager" />
          </a>
        ))}
      </div>
    </div>
    <p>Bachelor of Information Technology (Computer Science) - with Distinction</p>
    <p>Minors: Intelligent Systems, Computational and Simulation Science</p>
  </div>
</section>

<style>
  .profile-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(1.25rem, 4vw, 2.25rem);
    align-items: center;
    padding: clamp(1.65rem, 2.5vw, 2rem);
  }

  .avatar {
    width: clamp(6rem, 18vw, 10rem);
    image-rendering: auto;
  }

  .profile-copy {
    display: grid;
    gap: 0.55rem;
    line-height: 1.35;
  }

  .name-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.45rem;
    align-items: center;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
  }


  p {
    margin: 0;
    color: var(--foreground1);
  }

  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  .socials a {
    display: inline-grid;
    place-items: center;
    min-width: 1.5rem;
    min-height: 1.5rem;
  }

  .socials :is(img, .social-icon) {
    display: block;
    width: auto;
    height: 22px;
    max-width: none;
    filter: grayscale(1) brightness(1.8);
  }

  .social-icon {
    width: 27.5px;
    color: var(--foreground0);
  }


  .socials a:hover :is(img, .social-icon) {
    filter: none;
  }

  .socials a:hover .social-icon {
    color: var(--accent-cyan);
  }

  @media (max-width: 620px) {
    .profile-card {
      grid-template-columns: 1fr;
    }
    .avatar {
      justify-self: center;
    }

    .profile-card,
    .name-row,
    .socials {
      justify-content: center;
    }

    .profile-copy {
      text-align: center;
    }
  }
</style>
