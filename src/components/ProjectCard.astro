---
import { projectCategories, type Project, type ProjectCategoryId } from '../data/projects';

export interface Props {
  project: Project;
}

const { project } = Astro.props;
const category = projectCategories[project.category];
const statusLabel = project.status === 'wip' ? 'IN PROGRESS' : project.status.toUpperCase();
const categoryMarks: Record<ProjectCategoryId, string> = {
  'large-minecraft-mods': '▦',
  'small-minecraft-mods': '✦',
  'templates-starters': '</>',
  'minecraft-dev-tools': '⌘',
  'minecraft-datapacks': '{}',
  'browser-extensions': '◫',
  websites: '>_',
  'discord-bots': '◉',
};
---

<article class="project-card" data-status={project.status}>
  <div class="project-icon" aria-hidden="true">{categoryMarks[project.category]}</div>
  <div class="project-copy">
    <div class="project-meta">
      <span class="status">{statusLabel}</span>
      <span>{category.badge}</span>
    </div>
    <h3>
      {project.url ? <a href={project.url} target="_blank" rel="noreferrer">{project.name}</a> : project.name}
    </h3>
    <p>{project.description}</p>
    <ul aria-label={`${project.name} technologies`}>
      {project.technologies.slice(0, 3).map((technology) => <li>{technology}</li>)}
      {project.technologies.length > 3 && <li>+{project.technologies.length - 3}</li>}
    </ul>
  </div>
  {project.url && <a class="open-link" href={project.url} target="_blank" rel="noreferrer" aria-label={`Open ${project.name}`}><span aria-hidden="true">↗</span></a>}
</article>

<style>
  .project-card {
    position: relative;
    min-width: 0;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.9rem;
    padding: 1rem;
    border-block-start: 1px solid var(--border-subtle);
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    transition: border-color 170ms ease, background-color 170ms ease, translate 170ms ease;
  }

  .project-card:hover,
  .project-card:focus-within {
    translate: 0 -0.12rem;
    border-block-start-color: var(--accent-cyan);
    background: var(--surface-raised);
  }

  .project-icon {
    width: 2.4rem;
    height: 2.4rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--border-subtle);
    background: var(--background1);
    color: var(--accent-cyan);
    font: 700 0.88rem/1 var(--font-mono);
  }

  .project-card[data-status='released'] .project-icon {
    color: #7ee4a7;
  }

  .project-card[data-status='wip'] .project-icon {
    color: var(--accent-yellow);
  }

  .project-copy {
    min-width: 0;
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.7rem;
    color: var(--foreground2);
    font: 700 0.65rem/1.2 var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .status {
    color: var(--accent-cyan);
  }

  .project-card[data-status='released'] .status {
    color: #7ee4a7;
  }

  .project-card[data-status='wip'] .status {
    color: var(--accent-yellow);
  }

  h3 {
    margin-block: 0.55rem 0;
    padding-inline-end: 1.2rem;
    font-size: 1rem;
    line-height: 1.2;
  }

  h3 a {
    color: var(--foreground0);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--accent-cyan);
  }

  p {
    margin-block: 0.55rem 0;
    color: var(--foreground1);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-block: 0.75rem 0;
    padding: 0;
    list-style: none;
  }

  li {
    padding: 0.18rem 0.35rem;
    background: color-mix(in srgb, var(--accent-cyan) 8%, var(--background2));
    color: var(--foreground2);
    font: 0.65rem/1 var(--font-mono);
  }

  .open-link {
    position: absolute;
    inset: 0.85rem 0.85rem auto auto;
    color: var(--foreground2);
    font-family: var(--font-mono);
    text-decoration: none;
  }

  .open-link:hover {
    color: var(--accent-cyan);
  }

  @media (max-width: 420px) {
    .project-card {
      grid-template-columns: 1fr;
    }

    .project-icon {
      width: 2rem;
      height: 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card {
      transition: none;
    }
  }
</style>
