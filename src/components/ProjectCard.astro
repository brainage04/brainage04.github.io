---
import type { Project } from '../data/projects';

export interface Props {
  project: Project;
}

const { project } = Astro.props;
const status = project.status ?? 'project';
---

<article class="project-card terminal-panel" box-="square" shear-="top">
  <div class="project-card__meta">
    <span class="status-badge" is-="badge" variant-="background2" data-status={status}><span class="badge-label">{status.toUpperCase()}</span></span>
    <span class="category">{project.category}</span>
  </div>
  <h3><a href={project.url} target="_blank" rel="noreferrer">{project.name}</a></h3>
  <p>{project.description}</p>
  <ul class="tech-list" aria-label={`${project.name} technologies`}>
    {project.technologies.map((technology) => <li class="tech-badge" is-="badge" variant-="background1"><span class="badge-label">{technology}</span></li>)}
  </ul>
</article>

<style>
  .project-card {
    display: grid;
    align-content: start;
    gap: 1.05rem;
    padding: clamp(1.35rem, 2vw, 1.7rem);
    line-height: 1.35;
  }

  .project-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: center;
    color: var(--foreground2);
  }

  .category {
    font-size: 0.78rem;
    color: var(--foreground2);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transform: translateY(1px);
  }

  h3 {
    margin: 0;
    font-size: clamp(1.15rem, 2.5vw, 1.4rem);
    line-height: 1.2;
  }

  p {
    margin: 0;
    color: var(--foreground1);
    line-height: 1.5;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.7rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .status-badge,
  .tech-badge {
    --badge-pad: 1.18ch;
    align-items: center;
    height: calc(1lh + 2px);
    line-height: 1lh;
    background-image: linear-gradient(
      90deg,
      transparent 0,
      transparent calc(var(--badge-pad) - 1px),
      var(--badge-color) calc(var(--badge-pad) - 1px),
      var(--badge-color) calc(100% - var(--badge-pad) + 1px),
      transparent calc(100% - var(--badge-pad) + 1px),
      transparent
    );
  }

  .status-badge::before,
  .status-badge::after,
  .tech-badge::before,
  .tech-badge::after {
    width: var(--badge-pad);
    height: 100%;
  }

  .badge-label {
    display: block;
    transform: translateY(0.75px);
  }

  .status-badge {
    --badge-color: color-mix(in srgb, var(--background3) 82%, var(--foreground0) 10%);
    --badge-text: var(--background0);
    color: var(--badge-text);
    font-weight: 700;
  }

  .status-badge[data-status='released'] {
    --badge-color: color-mix(in srgb, #56d68a 84%, var(--foreground0));
  }

  .status-badge[data-status='template'] {
    --badge-color: color-mix(in srgb, var(--accent-cyan) 82%, var(--foreground0));
  }

  .status-badge[data-status='wip'],
  .status-badge[data-status='private'] {
    --badge-color: color-mix(in srgb, var(--accent-yellow) 82%, var(--foreground0));
  }

  .tech-badge {
    --badge-pad: 1.08ch;
    --badge-color: color-mix(in srgb, var(--background3) 72%, var(--accent-cyan) 18%);
    --badge-text: var(--foreground0);
    color: var(--badge-text);
  }
</style>
