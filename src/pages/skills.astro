---
import PageHeader from '../components/PageHeader.astro';
import SkillGroup from '../components/SkillGroup.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { skillGroups } from '../data/skills';
---

<SiteLayout title="Skills" description="Technical skills and tools used by brainage04.">
  <div class="site-stack">
    <PageHeader title="Skills" eyebrow="experience" description="Languages, frameworks, tools, and platforms I have used across university, Minecraft modding, web work, and personal projects." />
    <div class="grid">
      {skillGroups.map((group) => <SkillGroup title={group.title} items={group.items} />)}
    </div>
  </div>
</SiteLayout>
