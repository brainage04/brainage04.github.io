---
import PageHeader from '../../components/PageHeader.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { groupProjects, projects } from '../../data/projects';

const page = {
  title: 'Projects',
  description: 'Minecraft mods, datapacks, browser extensions, websites, Discord bots, and other software projects.',
};
const groupedProjects = groupProjects(projects);
const projectCountLabel = (count: number) => `${count} ${count === 1 ? 'project' : 'projects'}`;
const headingId = (category: string) => `heading-${category.replaceAll(' ', '-').toLowerCase()}`;
---

<SiteLayout title={page.title}>
  <div class="site-stack">
    <PageHeader title={page.title} description={page.description} />

    <section class="site-stack" aria-labelledby="all-projects-heading">
      {Object.entries(groupedProjects).map(([category, items]) => (
        <section class="site-stack" aria-labelledby={headingId(category)}>
          <div class="panel-header">
            <h3 id={headingId(category)}>{category}</h3>
            <span>{projectCountLabel(items.length)}</span>
          </div>
          <div class="grid">
            {items.map((project) => <ProjectCard project={project} />)}
          </div>
        </section>
      ))}
    </section>
  </div>
</SiteLayout>
