---
import PageHeader from '../../components/PageHeader.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import ProjectTabs from '../../components/ProjectTabs.astro';
import TerminalPanel from '../../components/TerminalPanel.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getFeaturedProjects, getProjectsByArea, projectAreaEntries } from '../../data/projects';

const projectAreaSummaries = projectAreaEntries.map(([area, page]) => ({
  ...page,
  count: getProjectsByArea(area).length,
}));
const featuredProjects = getFeaturedProjects();
---

<SiteLayout title="Projects" description="Browser extensions, websites, various tools, and a lot of Minecraft mods.">
  <div class="site-stack">
    <PageHeader title="Projects" description="Browser extensions, websites, various tools, and a lot of Minecraft mods." />
    <ProjectTabs />

    <div class="two-column">
      <TerminalPanel title="Project areas">
        <ul marker-="tree">
          {projectAreaSummaries.map((area) => (
            <li><a href={area.href}>{area.title}</a> - {area.count} {area.summary}</li>
          ))}
        </ul>
      </TerminalPanel>
      <TerminalPanel title="Notes">
        <p>
          Java projects are separated because most of my work is Minecraft related. Other projects cover Python, browser extensions, bots, and this website.
        </p>
      </TerminalPanel>
    </div>

    <section class="site-stack" aria-labelledby="featured-heading">
      <div class="panel-header">
        <h2 id="featured-heading">Featured</h2>
      </div>
      <div class="grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  </div>
</SiteLayout>
