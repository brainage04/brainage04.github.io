---
import ProjectCard from '../../components/ProjectCard.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { groupProjects, projects } from '../../data/projects';

const projectGroups = groupProjects(projects);
const projectCountLabel = (count: number) => `${count} ${count === 1 ? 'project' : 'projects'}`;
const headingId = (id: string) => `heading-${id}`;
---

<SiteLayout title="Projects">
  <div class="site-stack">
    <nav class="project-toc terminal-panel" box-="square" shear-="top" aria-labelledby="project-toc-title">
      <h1 id="project-toc-title">Table of Contents</h1>
      <ol>
        {projectGroups.map((group) => (
          <li><a href={`#${group.id}`}>{group.label}</a></li>
        ))}
      </ol>
    </nav>

    <section class="site-stack" aria-label="Project categories">
      {projectGroups.map((group) => (
        <section id={group.id} class="site-stack" aria-labelledby={headingId(group.id)}>
          <div class="panel-header project-group-header">
            <div>
              <h2 id={headingId(group.id)}>{group.label}</h2>
              <p>{group.summary}</p>
            </div>
            <span>{projectCountLabel(group.projects.length)}</span>
          </div>
          <div class="grid">
            {group.projects.map((project) => <ProjectCard project={project} />)}
          </div>
        </section>
      ))}
    </section>
  </div>
</SiteLayout>

<style>
  .project-toc h1 {
    margin: 0 0 1rem;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
  }

  .project-toc ol {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 17rem), 1fr));
    gap: 0.55rem 2rem;
    margin: 0;
  }

  .project-toc a {
    font-weight: 700;
  }

  .project-group-header {
    align-items: start;
  }

  .project-group-header > div {
    display: grid;
    gap: 0.35rem;
    max-width: 54rem;
  }

  .project-group-header p {
    margin: 0;
    color: var(--foreground1);
    line-height: 1.45;
  }
  @media (max-width: 520px) {
    .project-toc ol {
      gap: 0.65rem;
    }

    .project-group-header {
      display: grid;
      justify-items: start;
    }
  }

</style>
