---
import { getCollection } from 'astro:content';
import BlogCard from '../../components/BlogCard.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<SiteLayout title="Blog">
  <div class="blog-index">
    <header class="blog-header">
      <p class="eyebrow">Build notes and personal updates</p>
      <h1>Blog</h1>
      <p>Longer notes about software projects, Minecraft mod development and what I learn while building them.</p>
    </header>
    <div class="post-list">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>
  </div>
</SiteLayout>

<style>
  .blog-index {
    width: min(100%, 58rem);
    display: grid;
    gap: clamp(2.5rem, 7vw, 5rem);
    margin-inline: auto;
  }

  .blog-header {
    display: grid;
    gap: 0.8rem;
    padding-block: clamp(1rem, 4vw, 2rem);
  }

  .eyebrow {
    margin: 0;
    color: var(--accent-cyan);
    font: 700 0.78rem/1.2 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 12vw, 6.5rem);
    line-height: 0.85;
    letter-spacing: -0.07em;
  }

  .blog-header > p:last-child {
    max-width: 58ch;
    margin: 0;
    color: var(--foreground1);
    font-size: clamp(1rem, 2vw, 1.15rem);
  }

  .post-list {
    display: grid;
    gap: 0.4rem;
  }
</style>
