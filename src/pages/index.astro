---
import ProfileCard from '../components/ProfileCard.astro';
import ProjectShowcase from '../components/ProjectShowcase.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { getFeaturedProjects } from '../data/projects';

const featuredProjects = getFeaturedProjects().slice(0, 3);
---

<SiteLayout title="Home">
  <div class="home-stack">
    <ProfileCard />

    <section class="build-summary" aria-labelledby="build-summary-title">
      <div class="section-intro">
        <p class="eyebrow">What I build</p>
        <h2 id="build-summary-title">Useful software with the difficult parts finished.</h2>
        <p>My strongest work combines Minecraft systems, reusable developer infrastructure and small web tools built around real workflows.</p>
      </div>
      <div class="capability-list">
        <article>
          <span aria-hidden="true">01</span>
          <h3>Minecraft systems</h3>
          <p>Server-side gameplay, generated structures, HUDs and multiplayer utility mods.</p>
        </article>
        <article>
          <span aria-hidden="true">02</span>
          <h3>Developer tooling</h3>
          <p>Templates, libraries, asset pipelines and release automation that remove repeat work.</p>
        </article>
        <article>
          <span aria-hidden="true">03</span>
          <h3>Web utilities</h3>
          <p>Focused websites and browser extensions for tasks that deserve a simpler interface.</p>
        </article>
      </div>
    </section>

    <section aria-labelledby="featured-projects-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2 id="featured-projects-heading">Projects worth opening</h2>
        </div>
        <a href="/projects/">View the full catalogue <span aria-hidden="true">→</span></a>
      </div>
      <div class="showcase-grid">
        {featuredProjects.map((project, index) => <ProjectShowcase project={project} index={index} />)}
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .home-stack {
    display: grid;
    gap: clamp(3rem, 8vw, 6rem);
  }

  .section-intro {
    display: grid;
    gap: 0.75rem;
    max-width: 52rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent-cyan);
    font: 700 0.78rem/1.2 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-intro h2,
  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .section-intro > p:last-child {
    max-width: 62ch;
    margin: 0;
    color: var(--foreground1);
    font-size: 1.05rem;
  }

  .capability-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    margin-block-start: 1.5rem;
    background: var(--border-subtle);
  }

  .capability-list article {
    padding: clamp(1rem, 2.5vw, 1.5rem);
    background: var(--surface);
  }

  .capability-list span {
    color: var(--accent);
    font: 700 0.72rem/1 var(--font-mono);
  }

  .capability-list h3 {
    margin-block: 0.7rem 0;
    font-size: 1.05rem;
  }

  .capability-list p {
    margin-block: 0.6rem 0;
    color: var(--foreground1);
    font-size: 0.92rem;
  }

  .section-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-block-end: 1.4rem;
    padding-block-end: 0.8rem;
    border-block-end: 1px solid var(--border-subtle);
  }

  .section-heading > div {
    display: grid;
    gap: 0.5rem;
  }

  .section-heading > a {
    color: var(--foreground1);
    font: 700 0.88rem/1.2 var(--font-mono);
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.9rem, 2vw, 1.3rem);
  }

  @media (max-width: 900px) {
    .capability-list,
    .showcase-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
