---
import ProfileCard from '../components/ProfileCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TerminalPanel from '../components/TerminalPanel.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { getFeaturedProjects } from '../data/projects';

const featuredProjects = getFeaturedProjects();
---

<SiteLayout title="Home" description="Portfolio, projects, and blog for brainage04.">
  <div class="site-stack">
    <ProfileCard />

    <TerminalPanel title="About">
      <div class="about-copy">
        <p>
          Hello! My name is Thomas. I graduated from QUT Gardens Point in December 2025 with a Bachelor
          of Information Technology in Computer Science.
        </p>
        <p>I specialise in:</p>
        <ul marker-="tree">
          <li>Java (Minecraft modding)</li>
          <li>C# (Unity games)</li>
          <li>Python (game macros, web scrapers, data visualisation)</li>
        </ul>
        <p>I've been employed as a Graduate Associate Consultant since February 2026.</p>
      </div>
    </TerminalPanel>

    <section class="site-stack" aria-labelledby="featured-projects-heading">
      <div class="panel-header">
        <h2 id="featured-projects-heading">Featured projects</h2>
        <a href="/coding-projects/">View all projects</a>
      </div>
      <div class="grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .about-copy {
    display: grid;
    gap: 1rem;
  }

  .about-copy > * {
    margin-block: 0;
  }

  p {
    color: var(--foreground1);
  }
</style>
