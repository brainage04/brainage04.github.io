---
import ProfileCard from '../components/ProfileCard.astro';
import ProjectShowcase from '../components/ProjectShowcase.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { getFeaturedProjects } from '../data/projects';
import { githubStarLists } from '../data/starLists';

const featuredProjects = getFeaturedProjects().slice(0, 3);
---

<SiteLayout title="Home">
  <div class="home-stack">
    <ProfileCard />

    <section class="build-summary" aria-labelledby="build-summary-title">
      <div class="section-intro">
        <p class="eyebrow">What I make</p>
        <h2 id="build-summary-title">Mods, apps, tools and templates.</h2>
        <p>These are the same categories I use for my <a href="https://github.com/brainage04?tab=stars" target="_blank" rel="noreferrer">GitHub star lists</a>.</p>
      </div>
      <div class="capability-list">
        {githubStarLists.map((list) => (
          <article>
            <h3>{list.name}</h3>
            <p>{list.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section aria-labelledby="featured-projects-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2 id="featured-projects-heading">Featured projects</h2>
        </div>
        <a href="/projects/">View the full catalogue <span aria-hidden="true">→</span></a>
      </div>
      <div class="showcase-grid">
        {featuredProjects.map((project, index) => <ProjectShowcase project={project} index={index} />)}
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .home-stack {
    display: grid;
    gap: clamp(3rem, 8vw, 6rem);
  }

  .section-intro {
    display: grid;
    gap: 0.75rem;
    max-width: 52rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent-cyan);
    font: 700 0.78rem/1.2 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-intro h2,
  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .section-intro > p:last-child {
    max-width: 62ch;
    margin: 0;
    color: var(--foreground1);
    font-size: 1.05rem;
  }

  .capability-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    margin-block-start: 1.5rem;
    background: var(--border-subtle);
  }

  .capability-list article {
    padding: clamp(1rem, 2.5vw, 1.5rem);
    background: var(--surface);
  }

  .capability-list h3 {
    margin: 0;
    font-size: 1rem;
  }

  .capability-list p {
    margin-block: 0.6rem 0;
    color: var(--foreground1);
    font-size: 0.88rem;
  }

  .section-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-block-end: 1.4rem;
    padding-block-end: 0.8rem;
    border-block-end: 1px solid var(--border-subtle);
  }

  .section-heading > div {
    display: grid;
    gap: 0.5rem;
  }

  .section-heading > a {
    color: var(--foreground1);
    font: 700 0.88rem/1.2 var(--font-mono);
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.9rem, 2vw, 1.3rem);
  }

  @media (max-width: 900px) {
    .capability-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .showcase-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .capability-list {
      grid-template-columns: 1fr;
    }
  }
</style>
